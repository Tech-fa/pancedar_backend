{
  "name": "vigelon-backend",
  "version": "1.0.0",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "prebuild": "rimraf dist",
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "typeorm": "ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js",
    "migration:run": "npm run typeorm migration:run -- -d ./src/db/database.ts",
    "migration:generate": "npm run typeorm migration:generate  -- -d ./src/db/database.ts  ./src/migrations/$NAME",
    "migration:create": "npm run typeorm migration:create ./src/migrations/$NAME",
    "migration:revert": "npm run typeorm migration:revert -- -d ./src/db/database.ts",
    "migration:data-migrate": "ts-node ./src/data-migrate.ts",
    "ts:migration:run": "npm run typeorm migration:run -- -d ./src/db/psql.ts",
    "ts:migration:revert": "npm run typeorm migration:revert -- -d ./src/db/psql.ts",
    "prod:migrate": "npm run migration:run && npm run migration:data-migrate && npm run ts:migration:run",
    "migration:reset": "ts-node ./src/drop-recreate-db.ts && npm run migration:run",
    "migration:recreate": "ts-node ./src/drop-recreate-db.ts",
    "create:client": "ts-node ./src/create-client.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.911.0",
    "@aws-sdk/lib-storage": "^3.777.0",
    "@aws-sdk/s3-request-presigner": "^3.911.0",
    "@golevelup/nestjs-rabbitmq": "^6.0.2",
    "@google-cloud/pubsub": "^5.3.0",
    "@nestjs-modules/ioredis": "^2.0.2",
    "@nestjs/cache-manager": "^3.0.1",
    "@nestjs/common": "^11.1.6",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.6",
    "@nestjs/jwt": "^11.0.1",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.6",
    "@nestjs/schedule": "^6.0.1",
    "@nestjs/typeorm": "^11.0.0",
    "@sendgrid/mail": "^8.1.4",
    "@xenova/transformers": "^2.0.1",
    "axios": "~1.15.0",
    "bcrypt": "~6.0.0",
    "cache-manager": "^6.4.1",
    "cache-manager-redis-store": "^3.0.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "cron": "^4.3.3",
    "date-fns": "^4.1.0",
    "googleapis": "^171.4.0",
    "ioredis": "^5.6.1",
    "jsonwebtoken": "^9.0.2",
    "mammoth": "^1.12.0",
    "mysql2": "^3.14.0",
    "nest-winston": "^1.10.2",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "pdf-parse": "^2.4.5",
    "pg": "^8.20.0",
    "puppeteer": "^24.41.0",
    "reflect-metadata": "~0.2.2",
    "rimraf": "^6.1.0",
    "tesseract.js": "^7.0.0",
    "typeorm": "^0.3.21",
    "uuid": "^13.0.0",
    "winston": "^3.17.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.5",
    "@nestjs/schematics": "^10.2.2",
    "@nestjs/testing": "^11.0.12",
    "@types/express": "^5.0.1",
    "@types/jest": "29.5.14",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.13.14",
    "@types/pdf-parse": "^1.1.5",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^6.0.3",
    "@typescript-eslint/eslint-plugin": "^8.28.0",
    "@typescript-eslint/parser": "^8.28.0",
    "eslint": "^9.23.0",
    "eslint-config-prettier": "^10.1.1",
    "eslint-plugin-prettier": "^5.2.5",
    "jest": "29.7.0",
    "prettier": "^3.5.3",
    "source-map-support": "^0.5.21",
    "supertest": "^7.1.0",
    "ts-jest": "29.3.0",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "4.2.0",
    "typescript": "^5.8.2"
  },
  "resolutions": {
    "protobufjs": "7.5.5"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
